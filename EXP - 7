#include <stdio.h>
int main()
{
    int a[100], n, i, choice, pos, element;
    printf("Enter the number of elements: ");
    scanf("%d", &n);
    printf("Enter %d elements:\n", n);
    for (i = 0; i < n; i++)
        scanf("%d", &a[i]);
    do
    {
        printf("\n1. Insert\n2. Delete\n3. Display\n4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);
        switch (choice)
        {
        case 1: // Insert
            printf("Enter the position (1 to %d): ", n + 1);
            scanf("%d", &pos);
            printf("Enter the element to insert: ");
            scanf("%d", &element);
            for (i = n; i >= pos; i--)
                a[i] = a[i - 1];
            a[pos - 1] = element;
            n++;
            break;
        case 2: // Delete
            printf("Enter the position to delete (1 to %d): ", n);
            scanf("%d", &pos);
            for (i = pos - 1; i < n - 1; i++)
                a[i] = a[i + 1];
            n--;
            break;
        case 3: // Display
            printf("Array elements are:\n");
            for (i = 0; i < n; i++)
                printf("%d ", a[i]);
            printf("\n");
            break;
        case 4:
            printf("Exiting...\n");
            break;
        default:
            printf("Invalid choice!\n");
        }
    } while (choice != 4);
    return 0;
}
